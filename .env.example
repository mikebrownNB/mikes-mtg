# Real values are set in the Vercel dashboard (Project Settings -> Environment Variables).
# For local use, copy this file to .env.local and fill it in (.env.local is gitignored).

# --- Supabase ---
# From: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is server-only; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Cloud Vision (Phase 2) ---
# From: https://console.cloud.google.com (enable Vision API, create API key)
GOOGLE_VISION_API_KEY=

# --- Vercel cron auth (Phase 1: Scryfall nightly import) ---
# Any random long string. Vercel will pass this as the `Authorization: Bearer <secret>` header.
CRON_SECRET=
